# Persistência PostgreSQL (Supabase) do servidor do jogo.
# Sem essas variáveis, o servidor usa snapshot JSON local (dev/testes).
# Schema: supabase/migrations/ — aplique com `supabase db push` ou no SQL Editor.
SUPABASE_URL=https://tvaiqwpcxbqtdhvurilz.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Base pública do app: destino do link de acesso enviado por e-mail
# (https://<host>/auth/callback). Padrão: https://srv1745709.hstgr.cloud.
# Em dev com Supabase real, aponte para o servidor local:
APP_BASE_URL=http://localhost:8787
