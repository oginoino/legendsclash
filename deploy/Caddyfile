# Legends Clash — proxy reverso (Caddy).
#
# Com login real (códigos OTP e tokens de sessão), o tráfego precisa de TLS.
# O site é servido pelo hostname da VPS: o Caddy emite e renova o certificado
# (Let's Encrypt) sozinho e redireciona HTTP→HTTPS automaticamente. O upgrade
# de WebSocket em /ws é tratado pelo reverse_proxy — sem configuração extra —
# e o cliente passa a usar wss:// sozinho (detecta https em client/src/store.ts).
#
# Atenção: com o site nomeado, o acesso direto pelo IP deixa de responder —
# use sempre https://srv1745709.hstgr.cloud. Para trocar de domínio (ex.:
# legendsclash.cutia.tech), aponte o DNS para a VPS e substitua o hostname
# abaixo.

srv1745709.hstgr.cloud {
	encode zstd gzip
	reverse_proxy localhost:8787 {
		# Em reload de config o Caddy fecharia todos os WebSockets na hora,
		# derrubando as batalhas em andamento; com o delay, as conexões
		# antigas seguem vivas e migram naturalmente.
		stream_close_delay 1h
	}
}
