# Variáveis de produção do servidor. Copie para:
#   /etc/legendsclash/legendsclash.env   (dono root, chmod 600)
# e preencha a service role key. Sem essas variáveis, o servidor usa um
# snapshot JSON local (server/data/db.json) em vez do Postgres no Supabase.

SUPABASE_URL=https://tvaiqwpcxbqtdhvurilz.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Porta interna do Node. O Caddy faz proxy 80 -> 8787; não exponha a 8787.
PORT=8787

# Base pública do app — destino dos links de acesso por e-mail
# (opcional: este já é o padrão no código).
APP_BASE_URL=https://srv1745709.hstgr.cloud
